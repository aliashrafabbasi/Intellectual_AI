# Copy this file to ".env" and fill in values:
#   cp .env.example .env
#
# After MongoDB can be reached at MONGO_URI, initialize indexes once:
#   python migratedb.py
#
# Required for the chat API (Groq): get a key at https://console.groq.com/
GROQ_API_KEY=

# Optional: chat model (default: llama-3.1-8b-instant — fastest common Groq option)
# GROQ_MODEL=llama-3.1-8b-instant
# Separate fast model for chat titles (does not block streaming completion)
# GROQ_TITLE_MODEL=llama-3.1-8b-instant
# Max completion tokens (default 2048). Groq on_demand counts prompt + max_tokens toward ~6000 TPM.
# GROQ_MAX_TOKENS=2048
# Ceiling for (estimated prompt + max_tokens); lower if you still see 413 rate_limit_exceeded.
# GROQ_ON_DEMAND_TOKEN_BUDGET=5900
# GROQ_CHAT_TEMPERATURE=0.35
# Only last N prior messages are loaded (then trimmed to budgets below)
# CHAT_CONTEXT_MESSAGES=16
# Estimated max prompt tokens (Groq on_demand ~6000 hard cap — stay conservative)
# GROQ_MAX_PROMPT_TOKENS_ESTIMATE=4800
# Max characters per message (truncated with … if longer)
# CHAT_MESSAGE_MAX_CHARS=8000
# Max combined characters for all non-system messages (history + current)
# CHAT_MAX_REST_CHARS=14000

# MongoDB — chat history (required). Examples:
#   Local / Docker on host port 27017:
MONGO_URI=mongodb://127.0.0.1:27017
#   Atlas / cloud (replace with your connection string):
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
#
# Ensure MongoDB is running where this URI points (local install, systemd service, or Atlas).

# Browser origins allowed by FastAPI CORS (comma-separated). Must include your React dev URL.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend only (create frontend/.env): VITE_API_URL=http://127.0.0.1:8000
